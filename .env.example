# ==========================================================================
#  AI Business Assistant SaaS — Environment Variables
#  Copy this file to `.env.local` (local dev) and fill in real values.
#  NEVER commit `.env.local`. Only NEXT_PUBLIC_* vars are exposed to the browser.
# ==========================================================================

# --------------------------------------------------------------------------
# App
# --------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WIDGET_URL=http://localhost:3000/widget/widget.js
APP_ENV=development

# --------------------------------------------------------------------------
# Supabase (Postgres + pgvector + Realtime + Storage)
# --------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
# Anon / public key — legacy JWT key OR new-format `sb_publishable_...` key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (backend only) — legacy JWT key OR new-format `sb_secret_...` key
SUPABASE_SERVICE_ROLE_KEY=
# Optional: JWKS endpoint for verifying Supabase-issued JWTs (Module 3 auth)
SUPABASE_JWKS_URL=
DATABASE_URL=

# --------------------------------------------------------------------------
# AI Providers (at least one is required; provider layer is switchable)
# --------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

# --------------------------------------------------------------------------
# Default AI Settings (overridable per platform/company/bot via settings)
# --------------------------------------------------------------------------
DEFAULT_CHAT_PROVIDER=openai
DEFAULT_CHAT_MODEL=gpt-4o-mini
DEFAULT_ADVANCED_CHAT_MODEL=gpt-4o
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_RERANK_PROVIDER=cohere
DEFAULT_RERANK_MODEL=rerank-multilingual-v3.0

# --------------------------------------------------------------------------
# Stripe (billing, subscriptions, webhooks)
# --------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --------------------------------------------------------------------------
# Trigger.dev (scheduled sync / ingestion / background jobs)
# --------------------------------------------------------------------------
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# --------------------------------------------------------------------------
# Email (Resend / SendGrid / SES — choose one)
# --------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=

# --------------------------------------------------------------------------
# Shopify integration
# --------------------------------------------------------------------------
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,read_customers,write_draft_orders

# --------------------------------------------------------------------------
# WooCommerce integration
# --------------------------------------------------------------------------
WOOCOMMERCE_WEBHOOK_SECRET=

# --------------------------------------------------------------------------
# Security
# --------------------------------------------------------------------------
# 32-byte key, hex or base64. Used to encrypt integration tokens at rest.
ENCRYPTION_KEY=
JWT_SECRET=
ADMIN_SUPPORT_ACCESS_REQUIRED=true

# --------------------------------------------------------------------------
# Redis (optional — rate limiting / caching)
# --------------------------------------------------------------------------
REDIS_URL=
